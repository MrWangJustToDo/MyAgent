# ============================================================================
# My Agent — environment configuration
# ============================================================================
# Copy this file to `.env` and fill in the values you need.
#   cp .env.example .env
#
# Precedence: CLI flags > environment variables > defaults.
# Every variable below is OPTIONAL unless marked [required].
# ============================================================================


# ----------------------------------------------------------------------------
# Provider & endpoint
# ----------------------------------------------------------------------------

# Which backend provider to use. One of:
#   ollama            — local Ollama server (default)
#   openRouter        — OpenRouter aggregation gateway
#   openai-compatible — any OpenAI-compatible API (custom OpenAI-compatible endpoint)
#   deepseek          — DeepSeek official API
#PROVIDER=ollama

# Base URL of the model endpoint.
#   - ollama:            defaults to http://localhost:11434
#   - openai-compatible: the full API base URL (e.g. https://api.example.com/v1)
#   - openRouter/deepseek: ignored (provider has a fixed endpoint)
# Aliases: URL, OLLAMA_URL, OPENAI_COMPATIBLE_URL
#URL=http://localhost:11434

# API key for the provider.
#   - openRouter:        OpenRouter key  (alias: OPENROUTER_API_KEY)
#   - deepseek:          DeepSeek key    (alias: DEEPSEEK_API_KEY)
#   - openai-compatible: the endpoint's API key
#   - ollama:            usually not required
# Aliases: API_KEY, OPENROUTER_API_KEY, DEEPSEEK_API_KEY
#API_KEY=

# Model id to use. This is the string sent to the provider's API.
# Required — there is no default. Set via MODEL env or --model flag.
# Examples: qwen2.5-coder:7b, deepseek-chat, anthropic/claude-3.5-sonnet
#MODEL=qwen2.5-coder:7b


# ----------------------------------------------------------------------------
# Agent runtime
# ----------------------------------------------------------------------------

# Maximum number of agent loop iterations per turn. Default: 50.
#MAX_ITERATIONS=50


# ----------------------------------------------------------------------------
# Sandbox (CLI / Node host)
# ----------------------------------------------------------------------------
# Controls how shell commands and filesystem access are sandboxed.
#   local  — OS-level sandbox (dropped privileges / restricted env) [default]
#   native — no sandbox, runs directly in the host environment
#SANDBOX_ENV=local

# Suppress sandbox downgrade warning banners (set to 1 to silence).
#MY_AGENT_SANDBOX_QUIET=0


# ----------------------------------------------------------------------------
# Remote CoreEnv server
# ----------------------------------------------------------------------------
# When set, the CLI forwards fs/shell/env operations to a remote CoreEnv HTTP
# server instead of using the local Node environment. Use with `--remote` / `-R`
# or set REMOTE_URL. Example: http://localhost:3100
# Aliases: REMOTE, REMOTE_URL
#REMOTE=http://localhost:3100


# ----------------------------------------------------------------------------
# CoreEnv HTTP server (pnpm start:server)
# ----------------------------------------------------------------------------
# Port the CoreEnv server listens on. Default: 3100.
#SERVER_PORT=3100

# Root directory the server is allowed to operate within. Default: cwd.
#ROOT_PATH=

# Sandbox mode used by the server. Same values as SANDBOX_ENV. Default: local.
#SANDBOX_ENV=local


# ----------------------------------------------------------------------------
# MCP (Model Context Protocol)
# ----------------------------------------------------------------------------
# Path to an MCP server config file (JSON). If unset, MCP is disabled.
#MCP_CONFIG_PATH=


# ----------------------------------------------------------------------------
# Model metadata override (MODEL_* — optional)
# ----------------------------------------------------------------------------
# These variables supply or override the active model's metadata — context
# window, pricing, capabilities, reasoning config, etc.
#
# Use cases:
#   - The model is NOT in the built-in registry (e.g. a custom openai-compatible
#     endpoint) — supply the fields the agent needs.
#   - You want to OVERRIDE a registry entry's defaults.
#
# All MODEL_* fields are optional; only set the ones you care about.
# Any one of them being set is enough to activate the override.
#
# Numbers may use underscores as separators, e.g. 1_048_576.

# Display name shown in the UI. Falls back to the MODEL value.
#MODEL_NAME=

# Registry provider id. One of:
#   anthropic | openai | deepseek | google | ollama | open-router | xai
# Falls back to a value derived from PROVIDER when unset.
#MODEL_PROVIDER=

# Model string actually sent to the API. Defaults to the MODEL value.
#MODEL_API_NAME=

# Max input context window in tokens. Default if unset: 128000.
#MODEL_CONTEXT_WINDOW=128000

# Default max output tokens. Default if unset: 4096.
#MODEL_MAX_OUTPUT=4096

# Whether the model accepts image / multimodal input. true | false
# Setting true automatically adds the "vision" capability.
#MODEL_MULTIMODAL=false

# Pricing in USD per 1M tokens (all optional; 0 when omitted).
#MODEL_PRICE_INPUT=0
#MODEL_PRICE_OUTPUT=0
#MODEL_PRICE_CACHE_WRITE=0
#MODEL_PRICE_CACHE_READ=0

# Comma-separated capability list. Known values:
#   reasoning, vision, tool_calling, prompt_caching, streaming,
#   json_output, computer_use
#MODEL_CAPABILITIES=tool_calling,streaming

# Reasoning model config (all optional).
#   MODEL_REASONING_TAG    — tag name used to extract reasoning (e.g. "think")
#   MODEL_REASONING_EFFORT — default effort: low | medium | high
#   MODEL_REASONING_BUDGET — max thinking budget in tokens
#MODEL_REASONING_TAG=
#MODEL_REASONING_EFFORT=medium
#MODEL_REASONING_BUDGET=4096

# Mark this as the default model for its provider. true | false
#MODEL_IS_DEFAULT=false


# ----------------------------------------------------------------------------
# Node.js / build
# ----------------------------------------------------------------------------
# Usually set by the npm scripts; rarely needs manual configuration.
#NODE_ENV=production
