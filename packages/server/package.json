{
  "name": "@my-agent/server",
  "version": "0.0.1",
  "description": "CoreEnv-compatible HTTP server backed by @my-agent/node, with type-safe RPC client",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./client": {
      "types": "./dist/client.d.mts",
      "import": "./dist/client.mjs"
    }
  },
  "bin": {
    "my-agent-server": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "node dist/index.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.8.0",
    "@my-agent/core": "workspace:*",
    "@my-agent/node": "workspace:*",
    "dotenv": "^16.5.0",
    "hono": "^4.12.26",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsdown": "^0.21.10",
    "typescript": "^5.6.3"
  }
}
