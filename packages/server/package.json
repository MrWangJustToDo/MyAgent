{
  "name": "@my-agent/server",
  "version": "0.0.1",
  "description": "HTTP server exposing core Agent for browser extension and web clients",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "bin": {
    "my-agent-server": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "node dist/index.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.3",
    "@my-agent/core": "workspace:*",
    "ai": "^6.0.177",
    "dotenv": "^16.5.0",
    "hono": "^4.7.11"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsdown": "^0.21.10",
    "typescript": "^5.6.3"
  }
}
