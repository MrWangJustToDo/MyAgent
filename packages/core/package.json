{
  "name": "@my-agent/core",
  "version": "0.0.1",
  "description": "Core logic for My Agent",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --project tsconfig.typecheck.json",
    "validate:emit-agent-event": "pnpm run build && node scripts/validate-emit-agent-event.mjs",
    "validate:event-log-bridge": "pnpm run build && node scripts/validate-event-log-bridge.mjs",
    "validate:agent-status": "pnpm run build && node scripts/validate-agent-status.mjs",
    "validate:extract-assistant-text": "pnpm run build && node scripts/validate-extract-assistant-text.mjs",
    "validate:tanstack-adapter": "pnpm run build && node scripts/validate-tanstack-adapter.mjs",
    "validate:local-connect": "pnpm run build && node scripts/validate-local-connect.mjs",
    "validate:agent-ui-channel": "pnpm run build && node scripts/validate-agent-ui-channel.mjs",
    "validate:tanstack-tools": "pnpm run build && node scripts/validate-tanstack-tools.mjs",
    "validate:side-text-query": "pnpm run build && node scripts/validate-side-text-query.mjs",
    "validate:reactive-compact": "pnpm run build && node scripts/validate-reactive-compact.mjs",
    "validate:stream-errors": "pnpm run build && node scripts/validate-stream-errors.mjs",
    "validate:capability-message-utils": "pnpm run build && node scripts/validate-capability-message-utils.mjs",
    "validate:run-coordinator": "pnpm run build && node scripts/validate-run-coordinator.mjs",
    "validate:subagent-run-stats": "pnpm run build && node scripts/validate-subagent-run-stats.mjs",
    "validate:compaction-messages": "pnpm run build && node scripts/validate-compaction-messages.mjs",
    "validate:canonical-model-messages": "pnpm run build && node scripts/validate-canonical-model-messages.mjs",
    "validate:model-config": "pnpm run build && node scripts/validate-model-config.mjs",
    "validate:assert-async-iterable": "pnpm run build && node scripts/validate-assert-async-iterable.mjs",
    "validate:agent-context": "pnpm run build && node scripts/validate-agent-context.mjs",
    "validate:reasoning-echo": "pnpm run build && node scripts/validate-reasoning-echo.mjs",
    "validate:approval-middleware": "pnpm run build && node scripts/validate-status-middleware.mjs",
    "validate:status-middleware": "pnpm run build && node scripts/validate-status-middleware.mjs",
    "validate:lifecycle-middleware": "pnpm run build && node scripts/validate-lifecycle-middleware.mjs",
    "validate:tool-phase-utils": "pnpm run build && node scripts/validate-tool-phase-utils.mjs",
    "validate:session-sync-tracker": "pnpm run build && node scripts/validate-session-sync-tracker.mjs",
    "validate:empty-assistant-shell": "pnpm run build && node scripts/validate-empty-assistant-shell.mjs",
    "validate:incomplete-tool-calls": "pnpm run build && node scripts/validate-incomplete-tool-calls.mjs",
    "validate:tool-compact": "pnpm run build && node scripts/validate-tool-compact.mjs",
    "validate:tool-denial-reason": "pnpm run build && node scripts/validate-tool-denial-reason.mjs",
    "validate:streaming-callback": "pnpm run build && node scripts/validate-streaming-callback.mjs",
    "validate:memory-service": "pnpm run build && node scripts/validate-memory-service.mjs",
    "validate:summarization-budget": "pnpm run build && node scripts/validate-summarization-budget.mjs",
    "validate:subagent-bridge-ui": "pnpm run build && node scripts/validate-subagent-bridge-ui.mjs",
    "validate:mcp-prefer-multimodal": "pnpm run build && node scripts/validate-mcp-prefer-multimodal.mjs",
    "validate:command-job-registry": "pnpm run build && node scripts/validate-command-job-registry.mjs"
  },
  "dependencies": {
    "@tanstack/ai": "^0.40.0",
    "@tanstack/ai-anthropic": "^0.16.1",
    "@tanstack/ai-client": "^0.20.0",
    "@tanstack/ai-mcp": "^0.2.3",
    "@tanstack/ai-openai": "^0.16.0",
    "@tanstack/openai-base": "^0.9.7",
    "openai": "^6.45.0",
    "pathe": "^2.0.3",
    "turndown": "^7.2.4",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/turndown": "^5.0.6",
    "tsdown": "^0.21.10",
    "typescript": "^5.6.3"
  }
}
