{
  "name": "@my-agent/core",
  "version": "0.0.1",
  "description": "Core logic for My Agent",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --project tsconfig.typecheck.json",
    "validate:emit-agent-event": "pnpm run build && node scripts/validate-emit-agent-event.mjs",
    "validate:event-log-bridge": "pnpm run build && node scripts/validate-event-log-bridge.mjs",
    "validate:agent-status": "pnpm run build && node scripts/validate-agent-status.mjs",
    "validate:extract-assistant-text": "pnpm run build && node scripts/validate-extract-assistant-text.mjs",
    "validate:tanstack-adapter": "pnpm run build && node scripts/validate-tanstack-adapter.mjs",
    "validate:local-connect": "pnpm run build && node scripts/validate-local-connect.mjs",
    "validate:agent-ui-channel": "pnpm run build && node scripts/validate-agent-ui-channel.mjs",
    "validate:tanstack-tools": "pnpm run build && node scripts/validate-tanstack-tools.mjs",
    "validate:side-text-query": "pnpm run build && node scripts/validate-side-text-query.mjs",
    "validate:reactive-compact": "pnpm run build && node scripts/validate-reactive-compact.mjs",
    "validate:run-coordinator": "pnpm run build && node scripts/validate-run-coordinator.mjs",
    "validate:subagent-run-stats": "pnpm run build && node scripts/validate-subagent-run-stats.mjs",
    "validate:compaction-messages": "pnpm run build && node scripts/validate-compaction-messages.mjs",
    "validate:model-config": "pnpm run build && node scripts/validate-model-config.mjs"
  },
  "dependencies": {
    "@tanstack/ai": "^0.40.0",
    "@tanstack/ai-anthropic": "^0.16.1",
    "@tanstack/ai-client": "^0.20.0",
    "@tanstack/ai-mcp": "^0.2.3",
    "@tanstack/ai-openai": "^0.16.0",
    "pathe": "^2.0.3",
    "turndown": "^7.2.4",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/turndown": "^5.0.6",
    "tsdown": "^0.21.10",
    "typescript": "^5.6.3"
  }
}
