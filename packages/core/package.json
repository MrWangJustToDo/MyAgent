{
  "name": "@my-agent/core",
  "version": "0.0.1",
  "description": "Core logic for My Agent",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --project tsconfig.typecheck.json",
    "validate:emit-agent-event": "pnpm run build && node scripts/validate-emit-agent-event.mjs",
    "validate:agent-status": "pnpm run build && node scripts/validate-agent-status.mjs",
    "validate:subagent-preview": "pnpm run build && node scripts/validate-subagent-preview.mjs",
    "validate:extract-assistant-text": "pnpm run build && node scripts/validate-extract-assistant-text.mjs"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^3.0.1",
    "@ai-sdk/devtools": "^0.0.17",
    "@ai-sdk/mcp": "^2.0.3",
    "@ai-sdk/openai": "^4.0.2",
    "@ai-sdk/provider": "^4.0.0",
    "@ai-sdk/provider-utils": "^5.0.1",
    "@openrouter/ai-sdk-provider": "^2.10.0",
    "ai": "^7.0.4",
    "ai-sdk-ollama": "^4.0.0",
    "pathe": "^2.0.3",
    "turndown": "^7.2.4",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/turndown": "^5.0.6",
    "tsdown": "^0.21.10",
    "typescript": "^5.6.3"
  }
}
