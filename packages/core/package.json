{
  "name": "@my-agent/core",
  "version": "0.0.1",
  "description": "Core logic for My Agent",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./ext": {
      "types": "./dist/ext.d.mts",
      "import": "./dist/ext.mjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.35",
    "@ai-sdk/devtools": "^0.0.17",
    "@ai-sdk/mcp": "^1.0.46",
    "@ai-sdk/openai": "^3.0.69",
    "@anthropic-ai/sandbox-runtime": "^0.0.52",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "ai": "^6.0.199",
    "ai-sdk-ollama": "^3.8.6",
    "computesdk": "^2.6.0",
    "mime-types": "^3.0.2",
    "turndown": "^7.2.4",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.19.15",
    "@types/turndown": "^5.0.6",
    "tsdown": "^0.21.10",
    "typescript": "^5.6.3"
  }
}
