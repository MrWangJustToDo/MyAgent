{
  "name": "@my-agent/core",
  "version": "0.0.1",
  "description": "Core logic for My Agent",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./ext": {
      "types": "./dist/ext.d.mts",
      "import": "./dist/ext.mjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.36",
    "@ai-sdk/openai": "^3.0.53",
    "@computesdk/just-bash": "^0.4.8",
    "@computesdk/provider": "^1.3.0",
    "@openrouter/ai-sdk-provider": "^2.8.0",
    "ai": "^6.0.168",
    "ai-sdk-ollama": "^3.8.3",
    "computesdk": "^2.6.0",
    "just-bash": "^2.14.2",
    "mime-types": "^3.0.2",
    "turndown": "^7.2.4",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.19.15",
    "@types/turndown": "^5.0.6",
    "tsdown": "^0.21.9",
    "typescript": "^5.6.3"
  }
}
