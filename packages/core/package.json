{
  "name": "@my-agent/core",
  "version": "0.0.1",
  "description": "Core logic for My Agent",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./ext": {
      "types": "./dist/ext.d.mts",
      "import": "./dist/ext.mjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@computesdk/just-bash": "^0.4.0",
    "@computesdk/provider": "^1.0.28",
    "ai": "^6.0.116",
    "computesdk": "^2.3.0",
    "just-bash": "^2.12.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsdown": "^0.21.0",
    "typescript": "^5.6.3"
  }
}
