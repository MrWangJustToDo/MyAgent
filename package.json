{
  "name": "my-agent",
  "version": "0.0.1",
  "private": true,
  "description": "AI-powered agent with translation, chat, and more using Ollama",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm run build:core && pnpm -r build",
    "build:core": "pnpm --filter @my-agent/core build",
    "build:cli": "pnpm --filter @my-agent/cli build",
    "build:extension": "pnpm --filter @my-agent/extension build",
    "build:server": "pnpm --filter @my-agent/server build",
    "dev:core": "pnpm --filter @my-agent/core dev",
    "dev:cli": "pnpm --filter @my-agent/cli dev",
    "dev:extension": "pnpm --filter @my-agent/extension dev",
    "dev:server": "pnpm --filter @my-agent/server dev",
    "start:cli": "DEV=true NODE_ENV=development node --inspect ./main.mjs",
    "start:server": "cd packages/server && node ./dist/index.mjs",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "clean": "pnpm -p -r -c exec rm -rf dist dev .cache .next tsconfig.build.tsbuildinfo",
    "purge": "pnpm -p -r -c exec rm -rf node_modules && rm -rf node_modules"
  },
  "devDependencies": {
    "@my-agent/core": "workspace:*",
    "@my-agent/cli": "workspace:*",
    "@my-agent/server": "workspace:*",
    "eslint": "^9",
    "eslint-import-resolver-typescript": "^4.4.4",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "project-tool": "https://github.com/MrWangJustToDo/project-tool.git",
    "typescript": "^5.6.3"
  }
}
